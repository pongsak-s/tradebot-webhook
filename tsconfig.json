{
  "files": [],
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "apps/webhook" },
    { "path": "apps/executor" },
    { "path": "apps/ui" }
  ]
}
