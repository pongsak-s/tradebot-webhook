// Prisma schema for trading system
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Side {
  BUY
  SELL
}
enum QTYType {
  USDT
  CONTRACT
}
enum EntryType {
  MARKET
  LIMIT
}
enum SignalStatus {
  PENDING
  VALIDATED
  REJECTED
  PROCESSED
}

model Project {
  id           String          @id
  createdAt    DateTime        @default(now())
  signals      Signal[]
  executions   Execution[]
  positions    Position[]
  pnlSnapshots PnlSnapshot[]
}

model Signal {
  id           Int            @id @default(autoincrement())
  signalId     String         @unique
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id])
  raw          Json
  normalized   Json
  status       SignalStatus   @default(PENDING)
  createdAt    DateTime       @default(now())
  processedAt  DateTime?
  executions   Execution[]
}

model Execution {
  id           Int      @id @default(autoincrement())
  signal       Signal   @relation(fields: [signalId], references: [id])
  signalId     Int
  type         String
  status       String
  createdAt    DateTime @default(now())
}

model Position {
  id           Int      @id @default(autoincrement())
  project      Project  @relation(fields: [projectId], references: [id])
  projectId    String
  symbol       String
  side         Side
  qty          Float
  entryPrice   Float
  createdAt    DateTime @default(now())
}

model PnlSnapshot {
  id           Int      @id @default(autoincrement())
  project      Project  @relation(fields: [projectId], references: [id])
  projectId    String
  timestamp    DateTime @default(now())
  realized     Float
  unrealized   Float
}